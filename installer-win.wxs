<?xml version="1.0" encoding="UTF-8"?>
<!-- WiX installer for HandyPlayer (produces .msi) -->
<!-- Prerequisites: dotnet tool install global wix, wix extension add WixToolset.UI.wixext -->
<!-- Build: wix build installer-win.wxs -arch x64 -ext WixToolset.UI.wixext ... -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="HandyPlayer"
           Manufacturer="HandyPlayer"
           Version="$(var.Version)"
           UpgradeCode="B7E3A4F1-8C2D-4E5F-9A1B-3D6C8E2F7A94"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of HandyPlayer is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- App icon in Add/Remove Programs -->
    <Icon Id="AppIcon" SourceFile="src\HandyPlaylistPlayer.App\Assets\app-icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- Install directory chooser UI -->
    <WixVariable Id="WixUILicenseRtf" Value="installer-license.rtf" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <Feature Id="Main" Title="HandyPlayer" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- Directory layout -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="HandyPlayer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />

  </Package>

  <!-- Application files (auto-harvested from publish directory) -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)\**" />
    </ComponentGroup>
  </Fragment>

  <!-- Start Menu shortcut -->
  <Fragment>
    <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder"
               Guid="F8A92B1C-3D4E-5F6A-7B8C-9D0E1F2A3B4C">
      <Shortcut Id="StartMenuLink"
                Name="HandyPlayer"
                Target="[INSTALLFOLDER]HandyPlayer.exe"
                Icon="AppIcon"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\HandyPlayer"
                     Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
