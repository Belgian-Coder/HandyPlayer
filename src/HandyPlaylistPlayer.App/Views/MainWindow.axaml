<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HandyPlaylistPlayer.App.ViewModels"
        xmlns:views="using:HandyPlaylistPlayer.App.Views"
        x:Class="HandyPlaylistPlayer.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        Icon="avares://HandyPlayer/Assets/app-icon.png"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource AppBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation Sidebar — hidden in fullscreen -->
        <Border Grid.Column="0" Width="220"
                IsVisible="{Binding ShowSidebar}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0"
                ZIndex="2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10"
                            Margin="16,16,16,16">
                    <Image Source="avares://HandyPlayer/Assets/app-icon.png"
                           Width="32" Height="32" />
                    <TextBlock Text="HandyPlayer"
                               FontSize="{StaticResource FontSizeHeading}" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,12">
                    <TextBlock Text="Space: Play/Pause" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="Esc: Exit FS / E-Stop" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="F11/F: Fullscreen" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="←/→: Seek  ↑/↓: Volume" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="N/P: Next/Prev  M: Mute" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="+/−: Nudge Offset" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                    <TextBlock Text="O: Overrides  ?: Help" FontSize="{StaticResource FontSizeCaption}" Opacity="0.4" />
                </StackPanel>

                <ListBox SelectedIndex="{Binding SelectedNavIndex}"
                         Background="Transparent"
                         Margin="8,0">
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Now Playing">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M8 5v14l11-7z" Width="16" Height="16" />
                            <TextBlock Text="Now Playing" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Library">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z" Width="16" Height="16" />
                            <TextBlock Text="Library" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Playlists">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M15 6H3v2h12V6zm0 4H3v2h12v-2zM3 16h8v-2H3v2zM17 6v8.18c-.31-.11-.65-.18-1-.18-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3V8h3V6h-5z" Width="16" Height="16" />
                            <TextBlock Text="Playlists" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Patterns">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" Width="16" Height="16" />
                            <TextBlock Text="Patterns" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 00.12-.61l-1.92-3.32a.49.49 0 00-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 00-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 00-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 00-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1115.6 12 3.611 3.611 0 0112 15.6z" Width="16" Height="16" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" ToolTip.Tip="Statistics">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" Width="16" Height="16" />
                            <TextBlock Text="Stats" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Main Content Area — PlayerView always alive, other pages overlay on top -->
        <Panel Grid.Column="1">
            <!-- Player always stays in the visual tree so VLC VideoView is never destroyed -->
            <ContentControl Content="{Binding Player}" />

            <!-- Overlay for non-player pages — opaque background so player doesn't show through -->
            <Border IsVisible="{Binding IsOverlayVisible}"
                    Background="{DynamicResource AppBgBrush}"
                    ZIndex="1">
                <TransitioningContentControl Content="{Binding OverlayPage}">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.2" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Border>
        </Panel>

        <!-- Fullscreen first-use hint -->
        <Border Grid.ColumnSpan="2" ZIndex="50"
                IsVisible="{Binding ShowFullscreenHint}"
                IsHitTestVisible="False"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,40,0,0"
                Background="{DynamicResource OverlaySemiLightBrush}" CornerRadius="{StaticResource RadiusLg}" Padding="16,8">
            <TextBlock Text="Move mouse to the bottom of the screen to show controls. Press Esc to exit."
                       FontSize="{StaticResource FontSizeSubtitle}" Foreground="White" Opacity="0.9" />
        </Border>

        <!-- Keyboard shortcut help overlay — covers entire window -->
        <Border Grid.ColumnSpan="2" ZIndex="100"
                IsVisible="{Binding ShowShortcutHelp}"
                Background="{DynamicResource OverlayDarkBrush}"
                PointerPressed="OnShortcutOverlayClick">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource OverlayBgBrush}"
                    CornerRadius="{StaticResource RadiusLg}" Padding="32,24" MinWidth="400">
                <StackPanel Spacing="12">
                    <TextBlock Text="Keyboard Shortcuts" FontSize="{StaticResource FontSizeHeading}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Space" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Play / Pause" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="Escape" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Exit Fullscreen / Emergency Stop" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="F11 / F" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Toggle Fullscreen" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" FontWeight="SemiBold">&#x2190; / &#x2192;</TextBlock>
                            <TextBlock Grid.Column="1" Text="Seek Backward / Forward" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" FontWeight="SemiBold">&#x2191; / &#x2193;</TextBlock>
                            <TextBlock Grid.Column="1" Text="Volume Up / Down" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="M" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Toggle Mute" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="N / P" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Next / Previous Track" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="+ / &#x2212;" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Nudge Sync Offset" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="O" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Toggle Override Controls" Opacity="0.8" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="?" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Show / Hide This Help" Opacity="0.8" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="Click anywhere to close" FontSize="{StaticResource FontSizeSmall}" Opacity="0.4"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
