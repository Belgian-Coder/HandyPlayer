<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandyPlaylistPlayer.App.ViewModels"
             x:Class="HandyPlaylistPlayer.App.Views.QueuePanelView"
             x:DataType="vm:QueuePanelViewModel">
    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="4">
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="4,2,4,4" Spacing="4">
                <TextBlock Text="{Binding HeaderText}"
                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}" />
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <StackPanel.Styles>
                        <Style Selector="Button.mode-toggle">
                            <Setter Property="Opacity" Value="0.5" />
                        </Style>
                        <Style Selector="Button.mode-active">
                            <Setter Property="Opacity" Value="1.0" />
                        </Style>
                    </StackPanel.Styles>
                    <!-- Shuffle -->
                    <Button Command="{Binding CycleShuffleModeCommand}"
                            Padding="5,3" MinWidth="0" MinHeight="0"
                            Classes="mode-toggle"
                            Classes.mode-active="{Binding IsShuffleActive}"
                            ToolTip.Tip="Shuffle (click to cycle)">
                        <PathIcon Data="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"
                                   Width="14" Height="14" />
                    </Button>
                    <!-- Repeat -->
                    <Button Command="{Binding CycleRepeatModeCommand}"
                            Padding="5,3" MinWidth="0" MinHeight="0"
                            Classes="mode-toggle"
                            Classes.mode-active="{Binding IsRepeatActive}"
                            ToolTip.Tip="Repeat (click to cycle)">
                        <PathIcon Data="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"
                                   Width="14" Height="14" />
                    </Button>
                    <!-- Save as playlist -->
                    <Button Command="{Binding SaveAsPlaylistCommand}"
                            Padding="5,3" MinWidth="0" MinHeight="0"
                            ToolTip.Tip="Save queue as playlist">
                        <PathIcon Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                   Width="14" Height="14" />
                    </Button>
                    <!-- Sort -->
                    <Button Padding="5,3" MinWidth="0" MinHeight="0"
                            ToolTip.Tip="Sort queue">
                        <PathIcon Data="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"
                                   Width="14" Height="14" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Title A → Z"     Command="{Binding SortQueueCommand}" CommandParameter="Title" />
                                <MenuItem Header="Title Z → A"     Command="{Binding SortQueueCommand}" CommandParameter="TitleDesc" />
                                <Separator />
                                <MenuItem Header="Shortest first"  Command="{Binding SortQueueCommand}" CommandParameter="Duration" />
                                <MenuItem Header="Longest first"   Command="{Binding SortQueueCommand}" CommandParameter="DurationDesc" />
                                <Separator />
                                <MenuItem Header="Unwatched first" Command="{Binding SortQueueCommand}" CommandParameter="Unwatched" />
                                <MenuItem Header="Watched first"   Command="{Binding SortQueueCommand}" CommandParameter="Watched" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <!-- Next unwatched -->
                    <Button Command="{Binding JumpToNextUnwatchedCommand}"
                            Padding="5,3" MinWidth="0" MinHeight="0"
                            ToolTip.Tip="Jump to next unwatched">
                        <PathIcon Data="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"
                                   Width="14" Height="14" />
                    </Button>
                    <!-- Clear -->
                    <Button Command="{Binding ClearQueueCommand}"
                            Padding="5,3" MinWidth="0" MinHeight="0"
                            ToolTip.Tip="Clear queue">
                        <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                   Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </StackPanel>
            <!-- Save status -->
            <TextBlock Grid.Row="1" Text="{Binding SaveStatus}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.7"
                       Margin="4,0,4,2"
                       IsVisible="{Binding SaveStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Queue items -->
            <Panel Grid.Row="2">
                <ListBox x:Name="QueueList"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedItem}"
                         SelectionMode="Multiple">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Play Next"
                                      Command="{Binding PlayNextCommand}"
                                      CommandParameter="{Binding SelectedItem}" />
                            <MenuItem Header="Remove from Queue"
                                      Command="{Binding RemoveItemCommand}"
                                      CommandParameter="{Binding SelectedItem}" />
                            <MenuItem Header="Remove Selected"
                                      Command="{Binding RemoveSelectedCommand}"
                                      CommandParameter="{Binding #QueueList.SelectedItems}" />
                            <Separator />
                            <MenuItem Header="Delete from Hard Drive"
                                      Command="{Binding DeleteFromDiskCommand}"
                                      CommandParameter="{Binding SelectedItem}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="MinHeight" Value="26" />
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(2n)">
                            <Setter Property="Background" Value="{DynamicResource RowAltBrush}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:QueueItemViewModel">
                            <Border Padding="6,0,0,0"
                                    BorderBrush="Transparent" BorderThickness="2,2,0,0"
                                    Classes.now-playing="{Binding IsCurrent}"
                                    Classes.dragging-source="{Binding IsDraggingThis}">
                                <Border.Styles>
                                    <Style Selector="Border.now-playing">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        <Setter Property="Background" Value="{DynamicResource NowPlayingBgBrush}" />
                                    </Style>
                                    <Style Selector="Border.dragging-source">
                                        <Setter Property="Opacity" Value="0.35" />
                                    </Style>
                                </Border.Styles>
                                <ToolTip.Tip>
                                    <Image Source="{Binding Thumbnail}" Width="180" Height="120"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </ToolTip.Tip>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <!-- Watched eye icon -->
                                    <PathIcon Grid.Column="0"
                                              Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                              Width="12" Height="12" Margin="0,0,4,0"
                                              Opacity="0.6"
                                              VerticalAlignment="Center"
                                              IsVisible="{Binding IsWatched}"
                                              ToolTip.Tip="Watched" />
                                    <!-- Filename -->
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Classes.now-playing="{Binding IsCurrent}">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Setter Property="Opacity" Value="0.8" />
                                            </Style>
                                            <Style Selector="TextBlock.now-playing">
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Opacity" Value="1.0" />
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                    <!-- Script indicator -->
                                    <PathIcon Grid.Column="2"
                                              Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"
                                              Width="10" Height="10" Opacity="0.5"
                                              Margin="4,0" VerticalAlignment="Center"
                                              IsVisible="{Binding HasScript}"
                                              ToolTip.Tip="Has paired script" />
                                    <!-- Duration -->
                                    <TextBlock Grid.Column="3" Text="{Binding Duration}"
                                               FontSize="{StaticResource FontSizeCaption}" Opacity="0.5"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Drop indicator line — positioned by code-behind during drag -->
                <Border x:Name="DropIndicator" IsVisible="False" IsHitTestVisible="False"
                        Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        Background="{DynamicResource AccentBrush}" />

                <!-- Drag ghost — floating label following cursor during drag -->
                <Border x:Name="DragGhost" IsVisible="False" IsHitTestVisible="False"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Background="{DynamicResource SurfaceBrush}" Opacity="0.85"
                        Padding="8,4" CornerRadius="4"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                        MaxWidth="200">
                    <TextBlock x:Name="DragGhostText"
                               FontSize="{StaticResource FontSizeBody}"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFgBrush}" />
                </Border>
            </Panel>
        </Grid>
    </Border>
</UserControl>
