<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HandyPlaylistPlayer.App.Views.ConfirmDialog"
        Title="Confirm"
        Icon="avares://HandyPlayer/Assets/app-icon.png"
        Width="400" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
            <Button Content="Cancel" Click="OnCancel" Width="80" />
            <Button Content="Delete" Click="OnConfirm" Width="80"
                    Classes="accent" />
        </StackPanel>
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" VerticalAlignment="Center" />
    </DockPanel>
</Window>
