<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Brand / Accent Colors ═══ -->
    <Color x:Key="AccentColor">#4FC3F7</Color>
    <Color x:Key="AccentColorDark">#0288D1</Color>
    <Color x:Key="EmergencyRed">#CC0000</Color>
    <Color x:Key="ErrorBg">#442200</Color>
    <Color x:Key="ErrorFg">#FFAA44</Color>
    <Color x:Key="SuccessGreen">#4CAF50</Color>
    <Color x:Key="WarningYellow">#FFC107</Color>
    <Color x:Key="SurfaceDark">#1A1A2E</Color>
    <Color x:Key="AppBg">#0D0D1A</Color>
    <Color x:Key="OverlayBg">#FF1E1E2E</Color>
    <Color x:Key="PlaceholderText">#666666</Color>
    <Color x:Key="OverlaySemiLight">#CC333333</Color>
    <Color x:Key="OverlayDark">#CC000000</Color>
    <Color x:Key="CalibrationBg">#333333</Color>
    <Color x:Key="CardBg">#2A2A3E</Color>
    <Color x:Key="CardBorder">#3A3A50</Color>
    <Color x:Key="RowAlt">#18FFFFFF</Color>
    <Color x:Key="NowPlayingBg">#30FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentColorDark}" />
    <SolidColorBrush x:Key="EmergencyRedBrush" Color="{StaticResource EmergencyRed}" />
    <SolidColorBrush x:Key="ErrorBgBrush" Color="{StaticResource ErrorBg}" />
    <SolidColorBrush x:Key="ErrorFgBrush" Color="{StaticResource ErrorFg}" />
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreen}" />
    <SolidColorBrush x:Key="WarningYellowBrush" Color="{StaticResource WarningYellow}" />
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}" />
    <!-- AppBgBrush / SurfaceBrush — static fallbacks; replaced at runtime by AppThemes.Initialize() -->
    <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBg}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="OverlayBgBrush" Color="{StaticResource OverlayBg}" />
    <SolidColorBrush x:Key="PlaceholderTextBrush" Color="{StaticResource PlaceholderText}" />
    <SolidColorBrush x:Key="OverlaySemiLightBrush" Color="{StaticResource OverlaySemiLight}" />
    <SolidColorBrush x:Key="OverlayDarkBrush" Color="{StaticResource OverlayDark}" />
    <SolidColorBrush x:Key="CalibrationBgBrush" Color="{StaticResource CalibrationBg}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    <SolidColorBrush x:Key="RowAltBrush" Color="{StaticResource RowAlt}" />
    <SolidColorBrush x:Key="NowPlayingBgBrush" Color="{StaticResource NowPlayingBg}" />

    <!-- ═══ Spacing ═══ -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>

    <!-- Common Thickness values -->
    <Thickness x:Key="PageMargin">16</Thickness>
    <Thickness x:Key="CardPadding">16,12</Thickness>
    <Thickness x:Key="CardMargin">0,0,8,8</Thickness>

    <!-- ═══ Corner Radius ═══ -->
    <CornerRadius x:Key="RadiusSm">3</CornerRadius>
    <CornerRadius x:Key="RadiusMd">4</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>

    <!-- ═══ Typography ═══ -->
    <x:Double x:Key="FontSizeCaption">10</x:Double>
    <x:Double x:Key="FontSizeSmall">11</x:Double>
    <x:Double x:Key="FontSizeBody">12</x:Double>
    <x:Double x:Key="FontSizeSubtitle">13</x:Double>
    <x:Double x:Key="FontSizeTitle">16</x:Double>
    <x:Double x:Key="FontSizeHeading">18</x:Double>
    <x:Double x:Key="FontSizeDisplay">22</x:Double>
    <x:Double x:Key="FontSizeStat">24</x:Double>

    <!-- ═══ Sizes ═══ -->
    <x:Double x:Key="SidebarWidth">220</x:Double>
    <x:Double x:Key="QueuePanelWidth">260</x:Double>
    <x:Double x:Key="VolumeSliderWidth">80</x:Double>
    <x:Double x:Key="IconSizeSm">14</x:Double>
    <x:Double x:Key="IconSizeMd">16</x:Double>

</ResourceDictionary>
