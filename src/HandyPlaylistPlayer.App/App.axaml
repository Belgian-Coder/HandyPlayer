<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:HandyPlaylistPlayer.App"
             x:Class="HandyPlaylistPlayer.App.App"
             RequestedThemeVariant="Dark">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://HandyPlayer/Themes/AppTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Sortable column header button style -->
        <Style Selector="Button.header-sort">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.header-sort:pointerover">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Panel slide animations (collapse via MaxHeight + Opacity) -->
        <Style Selector="Border.panel-slide">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.25" Easing="CubicEaseOut" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Border.panel-slide.open">
            <Setter Property="MaxHeight" Value="400" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <!-- Error bar slide-down animation -->
        <Style Selector="Border.error-slide">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Border.error-slide.open">
            <Setter Property="MaxHeight" Value="200" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- Card-style section wrapper -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Library header row distinction -->
        <Style Selector="Border.library-header">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
        </Style>
        <Style Selector="Border.library-header Button.header-sort">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <!-- Now-playing highlight in queue -->
        <Style Selector="ListBoxItem.now-playing">
            <Setter Property="Background" Value="{DynamicResource NowPlayingBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2,0,0,0" />
        </Style>

        <!-- ═══ Button Variants ═══ -->

        <!-- Primary button: accent-colored fill -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        </Style>
        <Style Selector="Button.btn-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
        </Style>
        <Style Selector="Button.btn-primary:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)" />
        </Style>

        <!-- Secondary button: transparent with border -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        </Style>
        <Style Selector="Button.btn-secondary:pointerover">
            <Setter Property="Background" Value="#20FFFFFF" />
        </Style>
        <Style Selector="Button.btn-secondary:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)" />
        </Style>

        <!-- Danger button: red fill -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource EmergencyRedBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        </Style>
        <Style Selector="Button.btn-danger:pointerover">
            <Setter Property="Background" Value="#FF990000" />
        </Style>
        <Style Selector="Button.btn-danger:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)" />
        </Style>

        <!-- ═══ Seek Slider — larger hit area + hover highlight ═══ -->
        <Style Selector="Slider.seek-slider">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <!-- Widen the track for easier clicking -->
        <Style Selector="Slider.seek-slider /template/ Border#TrackBackground">
            <Setter Property="MinHeight" Value="6" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                    <DoubleTransition Property="MinHeight" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.seek-slider:pointerover /template/ Border#TrackBackground">
            <Setter Property="MinHeight" Value="10" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- Accent-colored fill track -->
        <Style Selector="Slider.seek-slider /template/ RepeatButton#PART_DecreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="MinHeight" Value="6" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MinHeight" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.seek-slider:pointerover /template/ RepeatButton#PART_DecreaseButton /template/ Border">
            <Setter Property="MinHeight" Value="10" />
        </Style>
        <!-- Thumb — always visible in accent color, grows on hover -->
        <Style Selector="Slider.seek-slider /template/ Thumb">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="-5,0,-5,0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.15" />
                    <DoubleTransition Property="Height" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.seek-slider /template/ Thumb /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style Selector="Slider.seek-slider:pointerover /template/ Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
        </Style>

        <!-- ═══ Icon Hover Tinting ═══ -->
        <!-- Transport and toolbar buttons: icon tints accent on hover, slight scale -->
        <Style Selector="Button:pointerover > PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button:pressed > PathIcon">
            <Setter Property="RenderTransform" Value="scale(1.1)" />
        </Style>
        <Style Selector="Button > PathIcon">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <!-- ═══ General button style: custom background + press animation ═══ -->
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <!-- ═══ Skeleton loading shimmer ═══ -->
        <Style Selector="Border.skeleton">
            <Setter Property="Background" Value="#20FFFFFF" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="0,3" />
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.6" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- ═══ Connection pulsing animation ═══ -->
        <Style Selector="Border.pulse-connecting">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.4" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- ═══ List item fade-in ═══ -->
        <Style Selector="ListBoxItem">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <!-- ═══ Theme-aware selection highlight ═══ -->
        <!-- Overrides FluentTheme's fixed system brushes so selection colors update with theme changes -->
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource SelectionBgBrush}" />
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SelectionHoverBrush}" />
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource SelectionBgBrush}" />
        </Style>

    </Application.Styles>
</Application>
